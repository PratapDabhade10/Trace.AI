PORT=5000

# MongoDB (Required for document storage)
MONGO_URI=mongodb://localhost:27017/trace_ai

# Groq AI (Required for answering questions and extraction)
GROQ_API_KEY=your_groq_api_key_here

# Neo4j (Graph Database - Optional but recommended)
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# Slack Integration (Optional)
SLACK_BOT_TOKEN=your_slack_bot_token_here

# Gmail OAuth Integration (Optional)
GMAIL_CLIENT_ID=your_google_client_id_here
GMAIL_CLIENT_SECRET=your_google_client_secret_here
GMAIL_REDIRECT_URI=http://localhost:5000/auth/google/callback
